# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform fee percentage (e.g. 2.5 = 2.5%)
STRIPE_PLATFORM_FEE_PERCENT=2.5
# Reservation deposit (GBP, shown to buyers on vehicle detail page)
RESERVATION_DEPOSIT_GBP=500
NEXT_PUBLIC_RESERVATION_DEPOSIT_GBP=500
# Approximate GBP → AED exchange rate for deposit storage (update periodically)
GBP_TO_AED_RATE=4.68

# TrustIn Escrow API
TRUSTIN_API_URL=https://api.trustin.com/v1
TRUSTIN_API_KEY=your-trustin-api-key
TRUSTIN_WEBHOOK_SECRET=your-trustin-webhook-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cron job secret (set in Vercel → Environment Variables)
CRON_SECRET=your-random-secret-here

# Exchange rates (use a provider like Open Exchange Rates in production)
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
